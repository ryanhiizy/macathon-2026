# Copy this file into the local env files you need:
# - `frontend/.env` for Expo app values
# - `backend/.env` for local AI server values

# Required for the Expo app once Supabase wiring is implemented.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_YOLO_API_URL=

# Add one provider key for the local AI server.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
