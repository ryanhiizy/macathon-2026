# Required for the Expo app.
EXPO_PUBLIC_SUPABASE_URL=
# Preferred for new setups.
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy fallback if you are still using the anon key format.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Required once the app calls the verifier server.
# Shared hosted verifier for this project:
EXPO_PUBLIC_PROMPT_API_URL=https://presence-ai-jackng96.fly.dev

# Optional demo-only bypass that skips AI verification and posts directly.
EXPO_PUBLIC_ENABLE_DEMO_PASS=false
